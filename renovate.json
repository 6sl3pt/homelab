{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":pinVersions"],
  "flux": {
    "fileMatch": ["\\.yaml$"]
  },
  "kubernetes": {
    "fileMatch": ["\\.yaml$"]
  },
  "packageRules": [
    {
      "matchManagers": ["flux", "kubernetes"],
      "separateMinorPatch": true
    }
  ],
  "dependencyDashboard": true,
  "minimumReleaseAge": "7 days"
}
